.env
.env.local
.env.*.local

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*

# 文档（减少上下文大小）
*.md
日志/
docs/

# 测试覆盖率
coverage/
.nyc_output/

# 临时文件
tmp/
temp/

