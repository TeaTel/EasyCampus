# Vercel部署环境变量配置示例
# 复制此文件为.env.local用于本地开发，或在Vercel项目中设置这些环境变量

# 后端API基础URL - 这是最重要的配置
# 本地开发时使用：http://localhost:8080
# Railway部署后使用：https://your-railway-project-name.up.railway.app
VITE_API_BASE_URL=https://your-railway-project-name.up.railway.app

# 应用名称
VITE_APP_NAME=校园二手交易平台

# 应用版本
VITE_APP_VERSION=1.0.0

# 是否启用调试模式
VITE_DEBUG=false

# 前端部署域名（用于CORS配置）
VITE_FRONTEND_URL=https://your-vercel-project.vercel.app

# 其他可选配置
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx